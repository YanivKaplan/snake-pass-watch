# Copy to .env and fill in for local docker-compose runs: `cp .env.example .env`
# .env is gitignored; never commit real values.

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# SQLAlchemy URL the app connects with. For the bundled Postgres service use the
# in-network address (host "db", port 5432), matching the credentials above:
#   postgresql+psycopg://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>
# To use SQLite locally instead: sqlite:////data/snake.db
DATABASE_URL=
