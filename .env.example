# Copy to .env and fill in for local docker-compose runs: `cp .env.example .env`
# .env is gitignored; never commit real values.

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Store backend: THE single switch ──────────────────────────────────────
# This one line selects the database; nothing else needs to change.
#
# Postgres (the bundled "db" service) — use the in-network address db:5432
# with the credentials above:
#   DATABASE_URL=postgresql+psycopg://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>
#
# SQLite (file on the host-mounted ./data volume):
#   DATABASE_URL=sqlite:////data/snake.db
DATABASE_URL=
