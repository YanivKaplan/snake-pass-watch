# Copy to .env (which is git-ignored) before running the server:
#   cp .env.example .env
#
# DATABASE_URL selects the store backend. Default to a local SQLite file; any
# SQLAlchemy URL works (e.g. postgresql+psycopg://...). Comment this out to run
# against the in-memory seeded store instead.
#
# Non-secret local config only — never put credentials here.
DATABASE_URL=sqlite:///./snake.db
