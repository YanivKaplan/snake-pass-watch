# Keep the build context small and reproducible (rebuild deps/artifacts fresh).
.git
**/node_modules
**/.venv
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.ruff_cache
frontend/dist
backend/*.db
# Host-mapped runtime data must never enter the build context/image.
data/
# Never bake local env/secrets into the image.
**/.env
